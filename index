<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: sans-serif; background: #F5F5F0; margin: 0; padding-bottom: 50px; }
    .header { background: #1E4620; color: white; text-align: center; padding: 20px; }
    .banner { background: #163514; color: #7FD98A; text-align: center; padding: 10px; font-weight: bold; }
    .container { max-width: 500px; margin: 0 auto; padding: 15px; }
    .card { background: white; border-radius: 12px; padding: 15px; margin-bottom: 15px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .drink-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .drink-card { border: 2px solid #EEE; border-radius: 10px; padding: 10px; text-align: center; cursor: pointer; transition: 0.2s; }
    .drink-card.selected { border-color: #1E4620; background: #F0F7F0; }
    .drink-img { width: 100%; border-radius: 6px; margin-bottom: 8px; }
    .name-zh { font-size: 14px; font-weight: bold; }
    .name-en { font-size: 11px; color: #888; }
    input, textarea { width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #DDD; border-radius: 6px; box-sizing: border-box; }
    .btn { width: 100%; padding: 15px; background: #1E4620; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; margin-top: 10px; }
  </style>
</head>
<body>
  <div class="header"><h1>參訪活動預約平台</h1></div>
  <div class="banner">歡迎蒞臨 · 2026 / 5 / 19</div>
  
  <div class="container">
    <div class="card">
      <label>您的姓名 Name</label>
      <input type="text" id="name" placeholder="請輸入姓名">
    </div>

    <div class="card">
      <label style="margin-bottom:10px; display:block;">飲品選擇 Beverage</label>
      <div class="drink-grid" id="grid">載入中...</div>
    </div>

    <div class="card">
      <label>備註 Notes</label>
      <textarea id="notes" rows="2"></textarea>
    </div>

    <button class="btn" onclick="submit()">確認送出 Confirm</button>
  </div>

  <script>
    let selectedId = null;
    let menu = [];

    window.onload = () => {
      google.script.run.withSuccessHandler(items => {
        menu = items;
        const grid = document.getElementById('grid');
        grid.innerHTML = '';
        items.forEach(item => {
          const div = document.createElement('div');
          div.className = 'drink-card';
          div.onclick = () => {
            selectedId = item.id;
            document.querySelectorAll('.drink-card').forEach(c => c.classList.remove('selected'));
            div.classList.add('selected');
          };
          div.innerHTML = `<img src="${item.img}" class="drink-img"><div class="name-zh">${item.name}</div><div class="name-en">${item.nameEn}</div>`;
          grid.appendChild(div);
        });
      }).getMenuItems();
    };

    function submit() {
      const name = document.getElementById('name').value;
      if (!name || !selectedId) return alert('請填寫姓名並選擇飲品');
      const item = menu.find(m => m.id === selectedId);
      const data = { visitDate: '2026-05-19', name: name, department: 'OSU', itemName: item.name, temperature: '-', iceLevel: '-', notes: document.getElementById('notes').value };
      google.script.run.withSuccessHandler(() => alert('送出成功！')).submitOrder(data);
    }
  </script>
</body>
</html>
